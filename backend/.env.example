# ==========================================
# MQTT Configuration
# ==========================================
# Option 1: LOCAL BROKER (Recommended - Raspberry Pi 5)
MQTT_BROKER=192.168.1.73
# MQTT_BROKER=localhost  # If running on same machine as backend

# Option 2: PUBLIC BROKER (For testing only)
# MQTT_BROKER=test.mosquitto.org

MQTT_PORT=1883
MQTT_TOPIC=aquatrace/sensors

# ==========================================
# MongoDB Configuration
# ==========================================
# Option 1: Local MongoDB
MONGO_URI=mongodb://localhost:27017

# Option 2: MongoDB Cloud (Atlas)
# MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net

DATABASE_NAME=aquatrace

# ==========================================
# Backend Server Configuration
# ==========================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ==========================================
# Optional: Authentication
# ==========================================
# MQTT_USERNAME=aquatrace
# MQTT_PASSWORD=your_password
